{
  "name": "vexaro-backend",
  "version": "1.0.0",
  "description": "",
  "main": "src/main.js",
  "scripts": {
    "dev": "nodemon --watch src --ext js --exec node src/main.js",
    "start": "node src/main.js",
    "seed": "node scripts/seed.js",
    "check": "node --check src/main.js",
    "create-indexes": "node scripts/create-indexes.js",
    "test": "jest --runInBand --forceExit",
    "test:watch": "jest --watch --runInBand",
    "test:coverage": "jest --coverage --runInBand --forceExit"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js",
      "**/__tests__/**/*.test.js",
      "**/src/modules/**/tests/*.test.js"
    ],
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "src/modules/finance/**/*.js",
      "src/utils/wallet.js",
      "src/modules/auth/auth.service.js",
      "src/modules/users/address-book.service.js",
      "src/modules/users/address-book.repository.js",
      "src/modules/users/address-book.controller.js"
    ],
    "coverageThreshold": {
      "global": {
        "lines": 60
      }
    },
    "testTimeout": 30000
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@sentry/node": "8.55.0",
    "axios": "^1.18.1",
    "bcryptjs": "^3.0.3",
    "compression": "^1.7.4",
    "cors": "^2.8.6",
    "csv-parse": "^7.0.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.7.2",
    "multer": "^2.2.0",
    "node-cron": "^4.5.0",
    "nodemailer": "^9.0.1",
    "pdfkit": "^0.19.1",
    "razorpay": "^2.9.6",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "winston": "3.17.0",
    "xlsx": "^0.18.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "fast-check": "^3.23.2",
    "jest": "29.7.0",
    "nodemon": "^3.1.14"
  }
}
